<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="rootPane" minHeight="500.0" minWidth="600.0" prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.proyectogestioneventos.controller.PerfilUsuarioController">
    <children>
        <Label text="Perfil de Usuario" AnchorPane.leftAnchor="50.0" AnchorPane.topAnchor="30.0">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <!-- Información actual del usuario -->
        <Label text="Información actual" underline="true" AnchorPane.leftAnchor="50.0" AnchorPane.topAnchor="70.0">
         <font>
            <Font name="System Bold" size="12.0" />
         </font></Label>
        <Label text="Nombre actual:" AnchorPane.leftAnchor="73.0" AnchorPane.topAnchor="100.0" />
        <Label fx:id="lblNombreActual" AnchorPane.leftAnchor="183.0" AnchorPane.topAnchor="100.0" />
        <Label text="Correo actual:" AnchorPane.leftAnchor="74.0" AnchorPane.topAnchor="125.0" />
        <Label fx:id="lblCorreoActual" AnchorPane.leftAnchor="184.0" AnchorPane.topAnchor="125.0" />
        <Label text="Rol:" AnchorPane.leftAnchor="74.0" AnchorPane.topAnchor="149.0" />
        <Label fx:id="lblRol" AnchorPane.leftAnchor="184.0" AnchorPane.topAnchor="149.0" />

        <!-- Campos para actualizar datos -->
        <Label text="Actualizar datos:" AnchorPane.leftAnchor="50.0" AnchorPane.topAnchor="200.0" />
        <Label text="Nuevo Nombre:" AnchorPane.leftAnchor="70.0" AnchorPane.topAnchor="230.0" />
        <TextField fx:id="campoNuevoNombre" AnchorPane.leftAnchor="200.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="225.0" />
        <Label text="Nuevo Email:" AnchorPane.leftAnchor="70.0" AnchorPane.topAnchor="270.0" />
        <TextField fx:id="campoNuevoEmail" AnchorPane.leftAnchor="200.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="265.0" />

        <!-- Sección de contraseña -->
        <Label text="Cambiar contraseña:" AnchorPane.leftAnchor="50.0" AnchorPane.topAnchor="310.0" />
        <Label text="Contraseña Actual:" AnchorPane.leftAnchor="70.0" AnchorPane.topAnchor="340.0" />
        <PasswordField fx:id="campoContrasenaActual" AnchorPane.leftAnchor="200.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="335.0" />
        <Label text="Nueva Contraseña:" AnchorPane.leftAnchor="70.0" AnchorPane.topAnchor="380.0" />
        <PasswordField fx:id="campoContrasenaNueva" AnchorPane.leftAnchor="200.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="375.0" />
        <Label text="Confirmar Contraseña:" AnchorPane.leftAnchor="70.0" AnchorPane.topAnchor="420.0" />
        <PasswordField fx:id="campoConfirmarContrasena" AnchorPane.leftAnchor="200.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="415.0" />

        <!-- Botones -->
        <Button onAction="#onGuardarCambios" text="Guardar Cambios" AnchorPane.bottomAnchor="20.0" AnchorPane.rightAnchor="120.0" />
        <Button onAction="#onCerrarClick" text="Cerrar" AnchorPane.bottomAnchor="20.0" AnchorPane.rightAnchor="50.0" />
    </children>
</AnchorPane>
