<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.proyectogestioneventos.controller.ServiciosAdicionalesController">
   <children>
      <VBox layoutX="14.0" layoutY="14.0" prefHeight="372.0" prefWidth="472.0" spacing="15.0" AnchorPane.bottomAnchor="14.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="14.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Servicios Adicionales">
               <font>
                  <Font size="22.0" />
               </font>
            </Text>
            <Label fx:id="lblCompra" text="Compra: [ID Compra]" />
            <VBox spacing="10.0">
               <children>
                  <CheckBox fx:id="chkAccesoVIP" mnemonicParsing="false" text="Acceso VIP (+$50.000)" />
                  <CheckBox fx:id="chkSeguroCancelacion" mnemonicParsing="false" text="Seguro de Cancelación (+$20.000)" />
                  <CheckBox fx:id="chkMerchandising" mnemonicParsing="false" text="Merchandising Oficial (+$80.000)" />
                  <CheckBox fx:id="chkParqueadero" mnemonicParsing="false" text="Parqueadero (+$15.000)" />
                  <CheckBox fx:id="chkAccesoPreferencial" mnemonicParsing="false" text="Acceso Preferencial (+$30.000)" />
               </children>
            </VBox>
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#onAgregarServiciosClick" text="Agregar Servicios" />
                  <Button mnemonicParsing="false" onAction="#onVolverClick" text="Volver" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
