<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="rootPane" minHeight="600.0" minWidth="800.0" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.proyectogestioneventos.viewcontroller.GestionZonasViewController">
   <children>
      <VBox spacing="15.0" AnchorPane.bottomAnchor="14.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="14.0">
         <children>
            <Label text="Gestión de Zonas">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
            <TableView fx:id="tablaZonas" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn prefWidth="75.0" text="ID Zona" />
                <TableColumn prefWidth="200.0" text="Nombre" />
                  <TableColumn prefWidth="150.0" text="Capacidad" />
                  <TableColumn prefWidth="150.0" text="Precio Base" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#onCreateZonaClick" text="Crear Zona" />
                  <Button mnemonicParsing="false" onAction="#onEditZonaClick" text="Editar Zona" />
                  <Button mnemonicParsing="false" onAction="#onDeleteZonaClick" text="Eliminar Zona" />
                  <Button mnemonicParsing="false" onAction="#onVolverClick" text="Volver" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>
