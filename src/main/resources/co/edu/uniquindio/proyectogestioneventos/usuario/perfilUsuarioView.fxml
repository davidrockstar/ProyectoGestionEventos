<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.proyectogestioneventos.controller.PerfilUsuarioController">
   <children>
      <Label layoutX="50.0" layoutY="50.0" text="Perfil de Usuario" />
      <Label layoutX="50.0" layoutY="100.0" text="Nombre:" />
      <TextField fx:id="campoNombre" layoutX="150.0" layoutY="100.0" prefWidth="300.0" />
      <Label layoutX="50.0" layoutY="140.0" text="Email:" />
      <TextField fx:id="campoEmail" layoutX="150.0" layoutY="140.0" prefWidth="300.0" />
      <Label layoutX="50.0" layoutY="180.0" text="Teléfono:" />
      <TextField fx:id="campoTelefono" layoutX="150.0" layoutY="180.0" prefWidth="300.0" />
      <Button layoutX="150.0" layoutY="250.0" mnemonicParsing="false" onAction="#onGuardarCambios" text="Guardar Cambios" />
      <Button layoutX="500.0" layoutY="360.0" mnemonicParsing="false" onAction="#onCerrarClick" text="Cerrar" />
   </children>
</AnchorPane>
