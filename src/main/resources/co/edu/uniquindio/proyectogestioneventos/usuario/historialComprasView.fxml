<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.proyectogestioneventos.controller.HistorialComprasController">
   <children>
      <Label layoutX="30.0" layoutY="25.0" text="Historial de Compras">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <TableView fx:id="tablaCompras" layoutX="30.0" layoutY="150.0" prefHeight="250.0" prefWidth="740.0">
        <columns>
          <TableColumn prefWidth="100.0" text="ID Compra" />
          <TableColumn prefWidth="200.0" text="Evento" />
            <TableColumn prefWidth="150.0" text="Fecha Compra" />
            <TableColumn prefWidth="100.0" text="Total" />
            <TableColumn prefWidth="100.0" text="Estado" />
        </columns>
      </TableView>
      <Label layoutX="30.0" layoutY="70.0" text="Filtros:" />
      <DatePicker fx:id="campoFecha" layoutX="30.0" layoutY="95.0" promptText="Fecha" />
      <TextField fx:id="campoEvento" layoutX="200.0" layoutY="95.0" promptText="Nombre Evento" />
      <ComboBox fx:id="cbEstado" layoutX="370.0" layoutY="95.0" prefWidth="150.0" promptText="Estado" />
      <Button layoutX="540.0" layoutY="95.0" mnemonicParsing="false" onAction="#onFiltrarClick" text="Filtrar" />
      <Button layoutX="30.0" layoutY="420.0" mnemonicParsing="false" onAction="#onVerDetalleClick" text="Ver Detalle" />
      <Button layoutX="150.0" layoutY="420.0" mnemonicParsing="false" onAction="#onDescargarReporteClick" text="Descargar Reporte" />
      <Button layoutX="700.0" layoutY="420.0" mnemonicParsing="false" onAction="#onVolverClick" text="Volver al Panel" />
   </children>
</AnchorPane>
