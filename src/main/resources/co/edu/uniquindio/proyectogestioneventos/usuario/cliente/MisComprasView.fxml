<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="rootPane" minHeight="500.0" minWidth="800.0" prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.proyectogestioneventos.controller.MisComprasController">
   <children>
      <Label text="Mis Compras Activas" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="25.0">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <TableView fx:id="tablaMisCompras" AnchorPane.bottomAnchor="110.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="70.0">
        <columns>
          <TableColumn prefWidth="100.0" text="ID Compra" />
          <TableColumn prefWidth="200.0" text="Evento" />
            <TableColumn prefWidth="150.0" text="Fecha Creación" />
            <TableColumn prefWidth="100.0" text="Total" />
            <TableColumn prefWidth="100.0" text="Estado" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Button onAction="#onModificarCompraClick" text="Modificar Compra" AnchorPane.bottomAnchor="60.0" AnchorPane.leftAnchor="30.0" />
      <Button onAction="#onCancelarCompraClick" text="Cancelar Compra" AnchorPane.bottomAnchor="60.0" AnchorPane.leftAnchor="180.0" />
      <Button onAction="#onPagarCompraClick" text="Pagar Compra" AnchorPane.bottomAnchor="60.0" AnchorPane.leftAnchor="330.0" />
      <Button onAction="#onVerDetalleCompraClick" text="Ver Detalle" AnchorPane.bottomAnchor="60.0" AnchorPane.leftAnchor="480.0" />
      <Button onAction="#onVolverClick" text="Volver al Panel" AnchorPane.bottomAnchor="20.0" AnchorPane.rightAnchor="30.0" />
   </children>
</AnchorPane>
