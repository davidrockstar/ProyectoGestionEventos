<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="rootPane" minHeight="500.0" minWidth="800.0" prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.proyectogestioneventos.controller.HistorialComprasController">
   <children>
      <Label text="Historial de Compras" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="25.0">
         <font>
            <Font size="20.0" />
         </font>
      </Label>
      <TableView fx:id="tablaCompras" AnchorPane.bottomAnchor="80.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="150.0">
        <columns>
          <TableColumn prefWidth="100.0" text="ID Compra" />
          <TableColumn prefWidth="200.0" text="Evento" />
            <TableColumn prefWidth="150.0" text="Fecha Compra" />
            <TableColumn prefWidth="100.0" text="Total" />
            <TableColumn prefWidth="100.0" text="Estado" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Label text="Filtros:" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="70.0" />
      <DatePicker fx:id="campoFecha" promptText="Fecha" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="95.0" />
      <TextField fx:id="campoEvento" promptText="Nombre Evento" AnchorPane.leftAnchor="200.0" AnchorPane.topAnchor="95.0" />
      <ComboBox fx:id="cbEstado" prefWidth="150.0" promptText="Estado" AnchorPane.leftAnchor="370.0" AnchorPane.topAnchor="95.0" />
      <Button onAction="#onFiltrarClick" text="Filtrar" AnchorPane.leftAnchor="540.0" AnchorPane.topAnchor="95.0" />
      <Button onAction="#onVerDetalleClick" text="Ver Detalle" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" />
      <Button onAction="#onDescargarReporteClick" text="Descargar Reporte" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="150.0" />
      <Button onAction="#onVolverClick" text="Volver al Panel" AnchorPane.bottomAnchor="30.0" AnchorPane.rightAnchor="30.0" />
   </children>
</AnchorPane>
